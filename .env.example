# ==========================================
# NoteHermes Environment Configuration
# ==========================================

# ==========================================
# DATABASE & REDIS
# ==========================================
# Docker Compose will spin up a Postgres container with these credentials by default.
DATABASE_URL=postgresql://notehermes:dev_password@postgres:5432/notehermes
REDIS_URL=redis://redis:6379

# For local development (without Docker):
# DATABASE_URL=postgresql://notehermes:dev_password@localhost:5432/notehermes

# ==========================================
# LLM PROVIDER (Alibaba DashScope / Coding)
# ==========================================
# Required: Get your key from Alibaba Cloud DashScope console.
DASHSCOPE_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
DASHSCOPE_API_KEY=your_api_key_here

# ==========================================
# TEAM MODEL ROUTING
# Each agent/task gets a specific model optimized for its job.
# ==========================================

# Agent #1 (Backend Dev) -> qwen3-coder-next (Code Specialist)
MODEL_BACKEND=qwen3-coder-next

# Agent #2 (Frontend Dev) -> qwen3.6-plus (Visual + Thinking)
MODEL_FRONTEND=qwen3.6-plus

# Agent #3 (AI/NLP Engineer) -> glm-5 (Reasoning Specialist)
MODEL_AI_NLP=glm-5

# Agent #4 (QA Engineer) -> MiniMax-M2.5 (Fast + Thinking)
MODEL_QA=MiniMax-M2.5

# Tony (Architect/Director) -> kimi-k2.5 (Vision + Deep Thinking)
MODEL_ARCHITECT=kimi-k2.5

# Default fallback model
MODEL_DEFAULT=qwen-plus

# ==========================================
# MICROSOFT 365 EMAIL CONFIGURATION
# ==========================================
# Set to True to use Century Internet (21Vianet) endpoints for China mainland.
# Set to False for International M365 endpoints.
USE_CHINA_M365=False

# Required for Graph API (OAuth) authentication.
# If using IMAP simple auth, you only need username/password per user.
M365_TENANT_ID=your_tenant_id
M365_CLIENT_ID=your_client_id
M365_CLIENT_SECRET=your_client_secret
